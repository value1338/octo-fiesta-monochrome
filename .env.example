# =============================================================================
# OCTO-FIESTA – Configuration
# Copy this file to .env and adjust the values.
# =============================================================================

# =============================================================================
# *** CHANGE – Your music folder path (used by docker-compose volume) ***
# Examples:  /mnt/user/music/music  |  C:/Users/YourName/Music  |  /home/user/Music
# =============================================================================
MUSIC_PATH=/path/to/your/music

# ===== NAVIDROME / SUBSONIC (Required) =====

# *** CHANGE – Navidrome server URL (IP and port) ***
# Format: http://IP:PORT  or  http://localhost:PORT
SUBSONIC_URL=http://localhost:4533

# *** CHANGE – Your Navidrome username ***
SUBSONIC_USERNAME=your_username

# *** CHANGE – Your Navidrome password ***
SUBSONIC_PASSWORD=your_password

# ===== MUSIC SERVICE =====
# *** CHANGE – Choose one: monochrome | squidwtf | Deezer | Qobuz ***
#
#   monochrome = Tidal via monochrome.tf instances (always Tidal, no sub-options)
#   squidwtf   = SquidWTF with sub-option: Qobuz or Tidal (see below)
#   Deezer     = Deezer (requires ARL token)
#   Qobuz      = Qobuz (requires user token)
#
MUSIC_SERVICE=monochrome

# ===== SQUIDWTF (only when MUSIC_SERVICE=squidwtf) =====
# *** CHANGE – Backend: Qobuz or Tidal ***
SQUIDWTF_SOURCE=Qobuz

# Audio quality (Tidal: HI_RES_LOSSLESS, LOSSLESS, HIGH, LOW)
# Qobuz: 27, 7, 6, 5
SQUIDWTF_QUALITY=LOSSLESS

# Timeout in seconds per API instance (default: 5)
SQUIDWTF_INSTANCE_TIMEOUT=5

# ===== DEEZER (only when MUSIC_SERVICE=Deezer) =====
DEEZER_ARL=your-deezer-arl-token
DEEZER_ARL_FALLBACK=
DEEZER_QUALITY=

# ===== QOBUZ (only when MUSIC_SERVICE=Qobuz) =====
QOBUZ_USER_AUTH_TOKEN=
QOBUZ_USER_ID=
QOBUZ_QUALITY=

# ===== STORAGE & OPTIONS =====
STORAGE_MODE=Permanent
ENABLE_EXTERNAL_PLAYLISTS=true
PLAYLISTS_DIRECTORY=playlists
EXPLICIT_FILTER=All
DOWNLOAD_MODE=Track
CACHE_DURATION_HOURS=1
AUTO_UPGRADE_QUALITY=false
TZ=Europe/London

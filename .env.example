# =============================================================================
# OCTO-FIESTA – Configuration
# Copy this file to .env and adjust the values.
# =============================================================================

# =============================================================================
# *** CHANGE THESE - Your music folder path (used by docker-compose volume) ***
# Examples:  /mnt/user/music/music  |  C:/Users/YourName/Music  |  /home/user/Music
# =============================================================================
MUSIC_PATH=/mnt/user/music/music

# ===== NAVIDROME / SUBSONIC (Required) =====

# Navidrome server URL – IP and port of your server
# Format: http://IP:PORT  or  http://localhost:PORT
# Examples: http://localhost:4533  |  http://192.168.1.100:4533
SUBSONIC_URL=http://localhost:4533

# Navidrome username (for automatic library scan)
SUBSONIC_USERNAME=your_username

# Navidrome password (for automatic library scan)
SUBSONIC_PASSWORD=your_password

# ===== MUSIC SERVICE =====
# SquidWTF (no login), Deezer or Qobuz
MUSIC_SERVICE=SquidWTF

# ===== SQUIDWTF / MONOCHROME =====
# Backend: Tidal or Qobuz
SQUIDWTF_SOURCE=Qobuz

# Qobuz API backend (only when SQUIDWTF_SOURCE=Qobuz):
#   squidwtf  = use qobuz.squid.wtf directly (fixed URL, no failover)
#   monochrome = use monochrome.tf instances (dynamic, with automatic failover) [default]
SQUIDWTF_QOBUZ_BACKEND=monochrome

# Audio quality for Tidal:
# HI_RES_LOSSLESS (FLAC 24-bit), LOSSLESS (FLAC 16-bit), HIGH (AAC 320), LOW (AAC 96)
SQUIDWTF_QUALITY=LOSSLESS

# Timeout in seconds per API instance (default: 5)
# Applies to Tidal source and monochrome Qobuz backend
SQUIDWTF_INSTANCE_TIMEOUT=5

# ===== DEEZER (only when MUSIC_SERVICE=Deezer) =====
DEEZER_ARL=your-deezer-arl-token
DEEZER_ARL_FALLBACK=
DEEZER_QUALITY=

# ===== QOBUZ (only when MUSIC_SERVICE=Qobuz) =====
QOBUZ_USER_AUTH_TOKEN=
QOBUZ_USER_ID=
QOBUZ_QUALITY=

# ===== STORAGE & OPTIONS =====
# Storage mode: Permanent (in library) or Cache (temporary)
STORAGE_MODE=Permanent

# External playlists (search, load Tidal playlists)
ENABLE_EXTERNAL_PLAYLISTS=true

# Playlist directory
PLAYLISTS_DIRECTORY=playlists

# Explicit content: All, ExplicitOnly, CleanOnly
EXPLICIT_FILTER=All

# Download mode: Track (single track) or Album (full album)
DOWNLOAD_MODE=Track

# Cache duration in hours (only when STORAGE_MODE=Cache)
CACHE_DURATION_HOURS=1

# Auto upgrade quality (e.g. MP3 → FLAC)
AUTO_UPGRADE_QUALITY=false

# Timezone (optional)
TZ=Europe/London

# ===== NAVIDROME / SUBSONIC (Pflichtangaben) =====
# URL deines Navidrome-Servers
Subsonic__Url=http://localhost:4533

# Navidrome-Benutzername (für automatischen Library-Scan)
Subsonic__Username=unavidrome_user

# Navidrome-Passwort (für automatischen Library-Scan)
Subsonic__Password=navidrome_password

# ===== MUSIK-SERVICE =====
# SquidWTF mit Tidal/Monochrome-Backend (keine Anmeldung nötig)
Subsonic__MusicService=SquidWTF

# ===== SQUIDWTF / MONOCHROME =====
# Backend: Tidal (nutzt Monochrome-Instanzen) oder Qobuz
SquidWTF__Source=Tidal

# Audio-Qualität für Tidal:
# HI_RES_LOSSLESS (FLAC 24-bit), LOSSLESS (FLAC 16-bit), HIGH (AAC 320), LOW (AAC 96)
SquidWTF__Quality=LOSSLESS

# Timeout in Sekunden pro API-Instanz (optional, Standard: 5)
# Bei Timeout wird automatisch zur nächsten Monochrome-Instanz gewechselt
SquidWTF__InstanceTimeout=5

# ===== SPEICHER =====
# Pfad für Downloads im Container (muss zum Volume in docker-compose.yml passen)
# Standard: /music (Volume-Mount von Host)
Library__DownloadPath=/music

# Speichermodus: Permanent (in Bibliothek) oder Cache (temporär)
Subsonic__StorageMode=Permanent

# ===== OPTIONEN =====
# Externe Playlists (Suche, Tidal-Playlists laden)
Subsonic__EnableExternalPlaylists=true

# Zeitzone
TZ=Europe/London
